<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <h1><%= title %></h1>
    <ul>
    <% posts.forEach(post => { %>
      <li><%= post.title %> - <%= post.date %></li>
    <% }) %>
    </ul>

  </body>
</html>
